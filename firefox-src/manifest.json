{
  "manifest_version": 2,
  "name": "iNaturalist Notifications",
  "version": "1.0",
  "description": "Shows your iNaturalist notifications in a popup",
  "browser_specific_settings": {
    "gecko": {
      "id": "inat-notifications@ksanderson",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "*://www.inaturalist.org/*",
    "*://www.inaturalist.ca/*",
    "*://inaturalist.org/*",
    "*://inaturalist.ca/*",
    "*://api.inaturalist.org/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_action": {
    "default_popup": "",
    "default_title": "iNat Notifications — loading...",
    "default_icon": "icon_gray.png"
  },
  "options_ui": {
    "page": "settings.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.inaturalist.org/*",
        "*://www.inaturalist.ca/*",
        "*://inaturalist.org/*",
        "*://inaturalist.ca/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
